<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.member.mapper.MemberMapper">



    <!-- 공통 resultMap 정의 -->

    <resultMap id="memberResultMap" type="com.example.demo.member.dto.MemberDTO">
        <id property="id" column="id"/>
        <result property="pw" column="pw"/>
        <result property="addr" column="addr"/>
        <result property="tel" column="tel"/>
    </resultMap>


    <!-- 회원 목록 조회 -->

    <select id="selectMemberList" resultMap="memberResultMap">

        SELECT
            id
             , pw
             , addr
             , tel
        FROM member
        ORDER BY id
    </select>



    <!-- 회원 상세 조회 -->

    <select id="selectMemberDetail" parameterType="string" resultMap="memberResultMap">

        SELECT
            id
             , pw
             , addr
             , tel
        FROM member
        WHERE id = #{id}

    </select>



    <!-- 회원 등록 -->

    <insert id="insertMember" parameterType="com.example.demo.member.dto.MemberDTO">

        INSERT INTO member (
                             id
                           , pw
                           , addr
                           , tel

        ) VALUES (
                   #{id}
                 , #{pw}
                 , #{addr}
                 , #{tel}
                )

    </insert>


    <!-- 회원 수정 -->

    <update id="updateMember" parameterType="com.example.demo.member.dto.MemberDTO">

        UPDATE member
        SET pw   = #{pw}
          , addr = #{addr}
          , tel  = #{tel}
        WHERE id = #{id}

    </update>

    <!-- 회원 삭제 -->

    <delete id="deleteMember" parameterType="string">
        DELETE FROM member
        WHERE id = #{id}
    </delete>
</mapper>